# ============================================================================
# DevAI Career Hub — Environment Variables
# ============================================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# NEVER commit .env to git. It is ignored by .gitignore.
# ============================================================================

# ── Supabase (Required) ─────────────────────────────────────────────────────
# Server-side keys (never exposed to the browser)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
SUPABASE_SERVICE_ROLE_KEY="sbp_..."

# Project ID (used internally)
SUPABASE_PROJECT_ID="your-project-id"

# Client-side keys (prefixed with VITE_ — shipped to the browser)
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
VITE_SUPABASE_PROJECT_ID="your-project-id"

# ── AI Providers (at least one required) ─────────────────────────────────────
GEMINI_API_KEY="your-gemini-api-key"
GROQ_API_KEY="your-groq-api-key"

# ── Deployment (Optional) ───────────────────────────────────────────────────
VERCEL_API_TOKEN="your-vercel-token"

# ── GitHub API (Optional — increases rate limit from 60 to 5,000 req/hr) ────
# Generate at https://github.com/settings/tokens
# GITHUB_TOKEN="ghp_..."

# ── Rate Limiting (Optional — override defaults) ────────────────────────────
# AI_RATE_LIMIT_DAILY_FREE=20
# AI_RATE_LIMIT_DAILY_AUTH=100
# AI_RATE_LIMIT_PER_MINUTE=5

# ── Node (Optional) ─────────────────────────────────────────────────────────
# NODE_ENV="development"
